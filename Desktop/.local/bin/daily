#!/usr/bin/sh
# Inspired by Calin Leaf Shade's dotfiles:
# https://github.com/calinleafshade/dots
set -eu

notes_folder=$WIKI_HOME/dailies
date_format="+%d-%m-%Y"

if [ $# -eq 1 ]; then
    year=$(date --date="$1" +%Y)
    month=$(date --date="$1" +%m)
    day=$(date --date="$1" +%d)
    filename=${notes_folder}/${year}/${month}/${day}.md
    fulldate=$(date --date="$1" ${date_format})
else
    year=$(date +%Y)
    month=$(date +%m)
    day=$(date +%d)
    filename=${notes_folder}/${year}/${month}/${day}.md
    fulldate=$(date ${date_format})
fi

mkdir -p $(dirname $filename)

if [ ! -f $filename ]; then
    echo "# 📓 Notes for ${fulldate}" > $filename
fi

nvim $filename
