# Jump fzf
cmd fzf_jump ${{
    res="$(find . -maxdepth 1 | fzf --reverse --header='Jump to location' | sed 's/\\/\\\\/g;s/"/\\"/g')"
    if [ -d "$res" ] ; then
        cmd="cd"
    elif [ -f "$res" ] ; then
        cmd="select"
    else
        exit 0
    fi
    lf -remote "send $id $cmd \"$res\""
}}

cmd openZathura ${{
		zathura "$f" &
	}}

cmd openThunar ${{
		thunar . &
	}}

cmd openVScode ${{
		code . &
	}}

cmd openAlacritty ${{
		alacritty  &
	}}

cmd openNvim ${{
		alacritty -e nvim &
	}}

